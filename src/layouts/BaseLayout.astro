---
import { ViewTransitions } from "astro:transitions"
import "../styles/global.css"

interface Props {
  title?: string
}

const { title = "Qombi Book Reader" } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-primary text-white h-14 flex items-center px-4 sticky top-0 z-50">
      <a href="/" class="text-lg font-semibold hover:opacity-90">Qombi Book Reader</a>
    </header>
    <main class="flex-1">
      <slot />
    </main>

    <!-- Focus panel -->
    <div class="focus-panel-backdrop" id="focus-backdrop" style="display:none" transition:persist></div>
    <div class="focus-panel" id="focus-panel" style="display:none" transition:persist>
      <div class="focus-panel-content" id="focus-panel-content"></div>
      <div class="focus-panel-controls" id="focus-panel-controls">
        <button class="focus-panel-btn" id="focus-play-btn" aria-label="Play">
          <svg id="fp-icon-play" width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <svg id="fp-icon-pause" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" style="display:none">
            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
          </svg>
        </button>
        <button class="focus-panel-btn focus-panel-stop" id="focus-stop-btn" aria-label="Stop" style="display:none">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6 6h12v12H6z"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Audio toast -->
    <div class="audio-toast" id="audio-toast" style="display:none" transition:persist></div>

    <!-- Mini player -->
    <div class="listen-player" id="listen-player" style="display:none" transition:persist>
      <div class="listen-player-image" id="player-image"></div>
      <div class="listen-player-overlay">
        <div class="listen-player-content">
          <button class="listen-player-btn" id="player-btn" aria-label="Play">
            <svg id="player-icon-play" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg id="player-icon-pause" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="display:none">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>
        </div>
      </div>
      <button class="listen-player-close" id="player-close" aria-label="Stop" style="display:none">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
        </svg>
      </button>
      <div class="listen-player-pulse" id="player-pulse" style="display:none"></div>
    </div>

    <script>
      import {
        $audioPlayState,
        $isPlaying,
        $playerVisible,
        $focusMode,
        $pausedState,
        $currentSegmentIdx,
        $segmentEntries,
        $audioPagePath,
        $playerCardInfo,
        $audioToast,
        playSegment,
        pausePlayback,
        resumePlayback,
        stopAll,
        unlockAudio,
      } from "../stores/audio-store"

      const unlockEvents = ["touchstart", "click"] as const
      function onFirstInteraction() {
        unlockAudio()
        for (const evt of unlockEvents) {
          document.removeEventListener(evt, onFirstInteraction, true)
        }
      }
      for (const evt of unlockEvents) {
        document.addEventListener(evt, onFirstInteraction, true)
      }

      function initAudioUI() {
        const focusBackdrop = document.getElementById("focus-backdrop")!
        const focusPanel = document.getElementById("focus-panel")!
        const focusPanelContent = document.getElementById("focus-panel-content")!
        const focusPanelControls = document.getElementById("focus-panel-controls")!
        const focusPlayBtn = document.getElementById("focus-play-btn")!
        const focusStopBtn = document.getElementById("focus-stop-btn")!
        const fpIconPlay = document.getElementById("fp-icon-play")!
        const fpIconPause = document.getElementById("fp-icon-pause")!

        const playerEl = document.getElementById("listen-player")!
        const playerImage = document.getElementById("player-image")!
        const playerBtn = document.getElementById("player-btn")!
        const playerClose = document.getElementById("player-close")!
        const playerPulse = document.getElementById("player-pulse")!
        const playerIconPlay = document.getElementById("player-icon-play")!
        const playerIconPause = document.getElementById("player-icon-pause")!

        let lastKenBurnsVariant = 0

        function populateFocusPanel(idx: number) {
          const entries = $segmentEntries.get()
          const entry = entries[idx]
          if (!entry) return
          const el = document.querySelector(`[data-section-idx="${entry.sectionIndex}"]`)

          focusPanelContent.innerHTML = ""

          if (el) {
            const clone = el.cloneNode(true) as HTMLElement
            clone.removeAttribute("id")
            clone.style.cursor = "default"
            clone.classList.remove("verse-focus-active")
            focusPanelContent.appendChild(clone)
            applyKenBurnsToImages(entry)

            const imagesContainer = focusPanelContent.querySelector(".listen-verse-images") as HTMLElement
            if (imagesContainer) {
              imagesContainer.style.position = "relative"
              imagesContainer.appendChild(focusPanelControls)
            } else {
              focusPanelContent.appendChild(focusPanelControls)
            }
          }

          focusPanel.scrollTop = 0
        }

        function applyKenBurnsToImages(entry: any) {
          const images = focusPanelContent.querySelectorAll(".listen-verse-images img")
          if (!images.length) return

          const duration = entry ? Math.max(entry.endTime - entry.startTime, 5) : 10
          const perImage = duration / images.length

          images.forEach((img) => {
            let variant = Math.floor(Math.random() * 4) + 1
            if (variant === lastKenBurnsVariant) variant = (variant % 4) + 1
            lastKenBurnsVariant = variant
            img.classList.add(`ken-burns-${variant}`)
            ;(img as HTMLElement).style.animation = `kenBurns${variant} ${perImage}s linear forwards`
          })
        }

        function showFocusPanel(idx: number) {
          populateFocusPanel(idx)
          focusBackdrop.style.display = ""
          focusPanel.style.display = ""
        }

        function hideFocusPanel() {
          focusPanel.appendChild(focusPanelControls)
          focusBackdrop.style.display = "none"
          focusPanel.style.display = "none"
          focusPanelContent.innerHTML = ""
        }

        function isOnAudioPage() {
          const audioPath = $audioPagePath.get()
          if (!audioPath) return false
          const currentPath = window.location.pathname.replace(/\/$/, "").toLowerCase()
          const normalizedAudioPath = audioPath.replace(/\/$/, "").toLowerCase()
          return currentPath === normalizedAudioPath || currentPath === `/${normalizedAudioPath}`
        }

        function syncHighlight() {
          document.querySelectorAll(".verse-focus-active").forEach((el) =>
            el.classList.remove("verse-focus-active"),
          )
          const isActive = $audioPlayState.get() !== "idle" || !!$pausedState.get()
          if (!isActive || !isOnAudioPage()) return

          const entries = $segmentEntries.get()
          const idx = $currentSegmentIdx.get()
          const sectionIdx = entries[idx]?.sectionIndex ?? 0
          const card = document.querySelector(`[data-section-idx="${sectionIdx}"]`)
          if (card) card.classList.add("verse-focus-active")
        }

        function scrollToSection(sectionIdx: number) {
          const card = document.querySelector(`[data-section-idx="${sectionIdx}"]`)
          if (!card) return
          const cardRect = card.getBoundingClientRect()
          const viewportCenter = window.innerHeight / 2
          const cardCenter = cardRect.top + cardRect.height / 2
          const delta = cardCenter - viewportCenter
          window.scrollBy({ top: delta, behavior: "smooth" })
        }

        $focusMode.subscribe((active: boolean) => {
          if (active) {
            document.body.classList.add("focus-mode")
            playerEl.style.display = "none"
            const entries = $segmentEntries.get()
            const idx = $currentSegmentIdx.get()
            const sectionIdx = entries[idx]?.sectionIndex ?? 0
            requestAnimationFrame(() => scrollToSection(sectionIdx))
            showFocusPanel(idx)
          } else {
            document.body.classList.remove("focus-mode")
            hideFocusPanel()
            if ($playerVisible.get()) {
              playerEl.style.display = ""
            }
          }
          syncHighlight()
        })

        $playerVisible.subscribe((visible: boolean) => {
          if ($focusMode.get()) {
            playerEl.style.display = "none"
          } else {
            playerEl.style.display = visible ? "" : "none"
          }
          if (!visible) {
            playerImage.innerHTML = ""
          }
        })

        $isPlaying.subscribe((playing: boolean) => {
          fpIconPlay.style.display = playing ? "none" : ""
          fpIconPause.style.display = playing ? "" : "none"
          focusStopBtn.style.display = playing ? "none" : ""
          if (playing) {
            focusPanelControls.style.top = "auto"
            focusPanelControls.style.left = "auto"
            focusPanelControls.style.bottom = "12px"
            focusPanelControls.style.right = "12px"
            focusPanelControls.style.transform = "none"
            const btn = focusPanelControls.querySelector(".focus-panel-btn") as HTMLElement
            if (btn) { btn.style.width = "40px"; btn.style.height = "40px" }
            const svgs = focusPanelControls.querySelectorAll(".focus-panel-btn svg")
            svgs.forEach((s) => { (s as HTMLElement).style.width = "24px"; (s as HTMLElement).style.height = "24px" })
          } else {
            focusPanelControls.style.top = "50%"
            focusPanelControls.style.left = "50%"
            focusPanelControls.style.bottom = ""
            focusPanelControls.style.right = ""
            focusPanelControls.style.transform = "translate(-50%, -50%)"
            const btn = focusPanelControls.querySelector(".focus-panel-btn") as HTMLElement
            if (btn) { btn.style.width = ""; btn.style.height = "" }
            const svgs = focusPanelControls.querySelectorAll(".focus-panel-btn svg")
            svgs.forEach((s) => { (s as HTMLElement).style.width = ""; (s as HTMLElement).style.height = "" })
          }

          playerIconPlay.style.display = playing ? "none" : ""
          playerIconPause.style.display = playing ? "" : "none"
          playerPulse.style.display = playing ? "" : "none"
          playerClose.style.display = playing ? "none" : ""

          document.body.classList.toggle("audio-paused", !playing)
          syncHighlight()
        })

        $currentSegmentIdx.subscribe((idx: number) => {
          syncHighlight()

          if ($audioPlayState.get() === "idle" && !$pausedState.get()) return

          const entries = $segmentEntries.get()
          const sectionIdx = entries[idx]?.sectionIndex ?? 0
          if ($focusMode.get()) {
            populateFocusPanel(idx)
            scrollToSection(sectionIdx)
          }
        })

        $playerCardInfo.subscribe(({ title, imageUrl }) => {
          if (imageUrl) {
            playerImage.innerHTML = `<img src="${imageUrl}" alt="${title}">`
          }
        })

        const toastEl = document.getElementById("audio-toast")!
        let toastTimer: ReturnType<typeof setTimeout> | null = null
        $audioToast.subscribe((msg: string) => {
          if (!msg) {
            toastEl.style.display = "none"
            return
          }
          toastEl.textContent = msg
          toastEl.style.display = "block"
          if (toastTimer) clearTimeout(toastTimer)
          toastTimer = setTimeout(() => $audioToast.set(""), 4000)
        })

        function togglePlayPause() {
          if ($audioPlayState.get() === "idle") {
            if ($pausedState.get()) {
              resumePlayback()
            } else {
              playSegment($currentSegmentIdx.get())
            }
          } else {
            pausePlayback()
          }
          unlockAudio()
        }

        focusPlayBtn.addEventListener("click", (e) => {
          e.stopPropagation()
          togglePlayPause()
        })

        focusStopBtn.addEventListener("click", (e) => {
          e.stopPropagation()
          stopAll()
        })

        focusBackdrop.addEventListener("click", () => {
          $focusMode.set(false)
        })

        playerEl.addEventListener("click", async () => {
          const audioPath = $audioPagePath.get()
          if (audioPath) {
            const currentPath = window.location.pathname.replace(/\/$/, "")
            const targetPath = audioPath.startsWith("/") ? audioPath : `/${audioPath}`
            if (currentPath !== targetPath) {
              const { navigate } = await import("astro:transitions/client")
              await navigate(targetPath)
              $focusMode.set(true)
              return
            }
          }
          $focusMode.set(true)
        })

        window.addEventListener("focus-panel-refresh", ((e: CustomEvent) => {
          if (!$focusMode.get()) return
          const idx = e.detail?.idx ?? $currentSegmentIdx.get()
          document.body.classList.add("focus-mode")
          playerEl.style.display = "none"
          const entries = $segmentEntries.get()
          const sectionIdx = entries[idx]?.sectionIndex ?? 0
          requestAnimationFrame(() => scrollToSection(sectionIdx))
          showFocusPanel(idx)
        }) as EventListener)

        playerBtn.addEventListener("click", (e) => {
          e.stopPropagation()
          togglePlayPause()
        })

        playerClose.addEventListener("click", (e) => {
          e.stopPropagation()
          stopAll()
        })

        window.addEventListener("wheel", () => {
          if ($focusMode.get()) $focusMode.set(false)
        })

        window.addEventListener("touchmove", () => {
          if ($focusMode.get()) $focusMode.set(false)
        })

        // Re-apply highlight after React re-renders strip the class
        const mainEl = document.querySelector("main")
        if (mainEl) {
          new MutationObserver(() => {
            const isActive = $audioPlayState.get() !== "idle" || !!$pausedState.get()
            if (!isActive || $focusMode.get() || !isOnAudioPage()) return
            const entries = $segmentEntries.get()
            const idx = $currentSegmentIdx.get()
            const sectionIdx = entries[idx]?.sectionIndex ?? 0
            const card = document.querySelector(`[data-section-idx="${sectionIdx}"]`)
            if (card && !card.classList.contains("verse-focus-active")) {
              card.classList.add("verse-focus-active")
            }
          }).observe(mainEl, { childList: true, subtree: true })
        }
      }

      if (!(window as any).__audioUIInitialized) {
        ;(window as any).__audioUIInitialized = true
        initAudioUI()
      }
    </script>
    <script>
      function scrollHashToCenter() {
        const hash = window.location.hash
        if (!hash) return
        const el = document.querySelector(hash)
        if (!el) return
        requestAnimationFrame(() => {
          const rect = el.getBoundingClientRect()
          const elCenter = rect.top + rect.height / 2
          const viewportCenter = window.innerHeight / 2
          window.scrollTo({ top: window.scrollY + elCenter - viewportCenter, behavior: "smooth" })
        })
      }

      // On initial page load with hash
      if (window.location.hash) {
        // Delay to let the page render
        setTimeout(scrollHashToCenter, 100)
      }

      // On same-page hash clicks
      document.addEventListener("click", (e) => {
        const link = (e.target as HTMLElement).closest("a[href^='#']")
        if (!link) return
        const hash = link.getAttribute("href")!
        const el = document.querySelector(hash)
        if (!el) return
        e.preventDefault()
        history.pushState(null, "", hash)
        const rect = el.getBoundingClientRect()
        const elCenter = rect.top + rect.height / 2
        const viewportCenter = window.innerHeight / 2
        window.scrollTo({ top: window.scrollY + elCenter - viewportCenter, behavior: "smooth" })
      })

      // On Astro view transition page load
      document.addEventListener("astro:page-load", () => {
        if (window.location.hash) {
          setTimeout(scrollHashToCenter, 100)
        }
      })
    </script>
  </body>
</html>
