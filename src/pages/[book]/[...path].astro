---
import BaseLayout from "../../layouts/BaseLayout.astro"
import PageReaderIsland from "../../components/PageReaderIsland"
import PageNavigationIsland from "../../components/PageNavigationIsland"
import {
  discoverBooks,
  loadBookStructure,
  loadLocaleData,
  loadMarkdownContent,
  loadAllPageTimings,
  loadCombinedTiming,
  discoverLocales,
} from "../../lib/book-loader"

export function getStaticPaths() {
  const bookIds = discoverBooks()
  const paths: any[] = []

  for (const id of bookIds) {
    const structure = loadBookStructure(id)
    if (!structure) continue
    const locales = discoverLocales(id)
    const locale = locales.length > 0 ? loadLocaleData(id, locales[0]) : null

    for (const cat of structure.categories) {
      // Category-level page (only for multi-category books)
      if (structure.categories.length > 1) {
        paths.push({
          params: { book: id, path: cat.id },
          props: {
            pageType: "category" as const,
            bookId: id,
            structure,
            categoryId: cat.id,
            localeData: locale,
          },
        })
      }

      const allPageIds = cat.stories.map((s) => s.id)
      const isSingleStory = cat.stories.length === 1

      // For single-story categories, combine all timing files into one
      let allTimings: Record<string, import("../../lib/types").PageTiming>
      if (isSingleStory) {
        const combined = loadCombinedTiming(id, cat.id)
        allTimings = { [cat.stories[0].id]: combined }
      } else {
        allTimings = loadAllPageTimings(id, cat.id, allPageIds)
      }

      // Page-level pages
      for (let i = 0; i < cat.stories.length; i++) {
        const page = cat.stories[i]
        const prevPage = i > 0 ? cat.stories[i - 1] : null
        const nextPage = i < cat.stories.length - 1 ? cat.stories[i + 1] : null

        paths.push({
          params: { book: id, path: `${cat.id}/${page.id}` },
          props: {
            pageType: "story" as const,
            bookId: id,
            categoryId: cat.id,
            pageId: page.id,
            localeData: locale,
            markdownContent: loadMarkdownContent(id, cat.id, page.id) || "",
            imageConfig: structure.imageConfig,
            audioUrl: cat.audioUrl,
            allTimings,
            allPageIds,
            prevPageUrl: prevPage ? `/${id}/${cat.id}/${prevPage.id}` : null,
            nextPageUrl: nextPage ? `/${id}/${cat.id}/${nextPage.id}` : null,
            currentPageNumber: i + 1,
            totalPages: cat.stories.length,
          },
        })
      }
    }
  }

  return paths
}

const props = Astro.props
const pageTitle = props.localeData?.bookTitle || props.bookId
---

<BaseLayout title={pageTitle}>
  {props.pageType === "category" ? (
    <div class="max-w-sm mx-auto p-4">
      <PageNavigationIsland
        client:load
        bookId={props.bookId}
        structure={props.structure}
        localeData={props.localeData}
        imageConfig={props.structure.imageConfig}
        defaultCategoryId={props.categoryId}
      />
    </div>
  ) : (
    <div class="max-w-sm mx-auto p-4">
      <PageReaderIsland
        client:load
        bookId={props.bookId}
        categoryId={props.categoryId}
        pageId={props.pageId}
        markdownContent={props.markdownContent}
        localeData={props.localeData}
        imageConfig={props.imageConfig}
        audioUrl={props.audioUrl}
        allTimings={props.allTimings}
        allPageIds={props.allPageIds}
        prevPageUrl={props.prevPageUrl}
        nextPageUrl={props.nextPageUrl}
        currentPageNumber={props.currentPageNumber}
        totalPages={props.totalPages}
      />
    </div>
  )}
</BaseLayout>
